ENVIRONMENT=development
LOG_LEVEL=INFO

# MongoDB Atlas connection string (create a free cluster at mongodb.com/atlas)
MONGODB_URI=mongodb+srv://<username>:<password>@<cluster-url>/?retryWrites=true&w=majority
MONGODB_DB_NAME=interview_coach

# ChromaDB local persistence directory (relative to backend/ when running locally)
CHROMA_PERSIST_DIR=./chroma_data
CHROMA_COLLECTION_NAME=resume_chunks
EMBEDDING_MODEL_NAME=sentence-transformers/all-MiniLM-L6-v2
EMBEDDING_CHUNK_SIZE=500
EMBEDDING_CHUNK_OVERLAP=100

# Comma-separated list of frontend origins allowed to call this API
CORS_ORIGINS=http://localhost:5173,http://127.0.0.1:5173

# JWT signing secret — generate a real one with: openssl rand -hex 32
# Never reuse this example value, and never commit the real one.
JWT_SECRET_KEY=replace-with-a-long-random-secret
JWT_ALGORITHM=HS256
JWT_ACCESS_TOKEN_EXPIRE_MINUTES=30

# Google Gemini API (official Google GenAI SDK)
GEMINI_API_KEY=replace-with-your-google-ai-studio-api-key
GEMINI_MODEL_NAME=gemini-2.5-flash
GEMINI_TIMEOUT_SECONDS=45
INTERVIEW_SEARCH_TOP_K=8
