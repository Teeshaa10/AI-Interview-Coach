ENVIRONMENT=development
LOG_LEVEL=INFO

# MongoDB Atlas connection string (create a free cluster at mongodb.com/atlas)
MONGODB_URI=mongodb+srv://<username>:<password>@<cluster-url>/?retryWrites=true&w=majority
MONGODB_DB_NAME=interview_coach

# ChromaDB local persistence directory (relative to backend/ when running locally)
CHROMA_PERSIST_DIR=./chroma_data

# Comma-separated list of frontend origins allowed to call this API
CORS_ORIGINS=http://localhost:5173,http://127.0.0.1:5173

# JWT signing secret — generate a real one with: openssl rand -hex 32
# Never reuse this example value, and never commit the real one.
JWT_SECRET_KEY=replace-with-a-long-random-secret
JWT_ALGORITHM=HS256
JWT_ACCESS_TOKEN_EXPIRE_MINUTES=30
